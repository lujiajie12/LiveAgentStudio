# LiveAgentStudio backend runtime configuration
# 复制为 backend/.env 后再填入真实值。

# 基础应用
PROJECT_NAME=LiveAgentStudio
VERSION=0.1.0
API_V1_STR=/api/v1
DEBUG=true

# CORS 与认证
CORS_ORIGINS_STR=http://localhost:3000,http://localhost:5173
JWT_SECRET=change-me
JWT_ALGORITHM=HS256
JWT_EXPIRE_SECONDS=28800
DEFAULT_DEMO_PASSWORD=demo

# 本地开发连接
DATABASE_URL=postgresql://root:change_me@localhost:5432/liveagent
REDIS_URL=redis://localhost:6379/0
MILVUS_HOST=localhost
MILVUS_PORT=19530
ES_HOST=localhost
ES_PORT=9200

# LLM / Router / Planner
LLM_API_KEY=
LLM_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
LLM_MODEL=qwen-plus
OPENAI_API_KEY=
OPENAI_BASE_URL=
ROUTER_MODEL=qwen-plus
ROUTER_TIMEOUT_MS=5000
PLANNER_MODEL=qwen-plus
PLANNER_TIMEOUT_MS=6000
PLANNER_MAX_STEPS=4
ROUTER_CONFIDENCE_THRESHOLD=0.6

# Web 搜索
SERPAPI_API_KEY=
SERPAPI_BASE_URL=https://serpapi.com/search.json
SERPAPI_ENGINE=google
SERPAPI_GL=cn
SERPAPI_HL=zh-cn
SERPAPI_NUM_RESULTS=5
SERPAPI_TIMEOUT_SECONDS=15.0

# 长期记忆
QA_MEMORY_ENABLED=false
MEM0_API_KEY=
MEM0_BASE_URL=
MEM0_ORG_ID=
MEM0_PROJECT_ID=
QA_MEMORY_AGENT_ID=qa_agent
QA_MEMORY_APP_ID=liveagent-studio
QA_MEMORY_TOP_K=4
QA_MEMORY_THRESHOLD=0.45
QA_MEMORY_RECALL_DEFAULT_LIMIT=3
QA_MEMORY_RECALL_MAX_ITEMS=5

# RAG / Embedding / Milvus
# 可填本地模型目录，也可填 Hugging Face 模型 ID。
EMBEDDING_MODEL=BAAI/bge-large-zh-v1.5
EMBEDDING_DIM=1024
EMBEDDING_DEVICE=cuda
EMBEDDING_BATCH_SIZE=64
MILVUS_INDEX_FLUSH_INTERVAL_CHUNKS=1024
MILVUS_RESET_SETTLE_SECONDS=15
DASHSCOPE_API_KEY=

# 流式输出与观测
SSE_EVENT_DELAY_MS=25
CHAT_TOKEN_CHUNK_SIZE=6
MEMORY_WINDOW_SIZE=12
MEMORY_TTL_SECONDS=7200
HOT_KEYWORDS_TTL_SECONDS=120
HIGH_FREQUENCY_QUESTION_LIMIT=5
METRICS_LOG_SAMPLE_LIMIT=500
OFFLINE_JOB_LOG_LINES=60

# 风控词支持 JSON 数组或英文逗号分隔
SENSITIVE_TERMS=["最强","国家级","包治百病"]
