# Docker Compose infrastructure variables only
# 这里只放容器、端口、数据库账户等基础设施参数。
# LLM / 搜索 / 记忆 / RAG 相关应用配置统一放到 backend/.env。

COMPOSE_PROJECT_NAME=liveagentstudio

# PostgreSQL
DB_USER=root
DB_PASSWORD=change_me
DB_NAME=liveagent
POSTGRES_PORT=5432

# Redis
REDIS_PORT=6379

# Backend / Frontend exposed ports
BACKEND_PORT=8000
FRONTEND_PORT=5173

# Build base images
BACKEND_BASE_IMAGE=python:3.11-slim
FRONTEND_NODE_BASE_IMAGE=node:18-alpine
FRONTEND_NGINX_BASE_IMAGE=nginx:alpine

# Elasticsearch
ELASTICSEARCH_PORT=9200
ELASTICSEARCH_JAVA_OPTS=-Xms1g -Xmx2g

# Milvus / MinIO
MINIO_API_PORT=9000
MINIO_CONSOLE_PORT=9001
MILVUS_PORT=19530
MILVUS_HEALTH_PORT=9091
MILVUS_IMAGE=milvusdb/milvus:v2.3.4
